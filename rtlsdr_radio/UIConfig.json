{
  "page": {
    "label": "FM/DAB Radio Configuration"
  },
  "sections": [
    {
      "id": "radio_settings",
      "element": "section",
      "label": "Radio Settings",
      "icon": "fa-signal",
      "onSave": {
        "type": "controller",
        "endpoint": "music_service/rtlsdr_radio",
        "method": "saveConfig"
      },
      "saveButton": {
        "label": "Save",
        "data": [
          "fm_enabled",
          "dab_enabled",
          "fm_gain",
          "dab_gain",
          "scan_sensitivity"
        ]
      },
      "content": [
        {
          "id": "fm_enabled",
          "element": "switch",
          "label": "Enable FM Radio",
          "value": true,
          "doc": "Enable FM radio reception"
        },
        {
          "id": "dab_enabled",
          "element": "switch",
          "label": "Enable DAB/DAB+ Radio",
          "value": true,
          "doc": "Enable DAB and DAB+ radio reception"
        },
        {
          "id": "fm_gain",
          "element": "input",
          "label": "FM Gain",
          "value": 50,
          "doc": "RTL-SDR gain for FM reception (0-100)"
        },
        {
          "id": "dab_gain",
          "element": "input",
          "label": "DAB Gain",
          "value": 80,
          "doc": "RTL-SDR gain for DAB reception (0-100)"
        },
        {
          "id": "scan_sensitivity",
          "element": "select",
          "label": "FM Scan Sensitivity",
          "value": {
            "value": 8,
            "label": "Balanced (+8 dB) - Good signals (recommended)"
          },
          "options": [
            {
              "value": 15,
              "label": "Conservative (+15 dB) - Very strong signals only"
            },
            {
              "value": 10,
              "label": "Moderate (+10 dB) - Strong signals"
            },
            {
              "value": 8,
              "label": "Balanced (+8 dB) - Good signals (recommended)"
            },
            {
              "value": 5,
              "label": "Sensitive (+5 dB) - All reasonable signals"
            },
            {
              "value": 3,
              "label": "Very Sensitive (+3 dB) - Weaker signals, may include noise"
            }
          ],
          "doc": "How sensitive the FM scanner should be when detecting stations. Higher values find only the strongest signals, lower values find more stations but may include noise."
        }
      ]
    },
    {
      "id": "manual_playback",
      "element": "section",
      "label": "Manual Playback",
      "icon": "fa-play-circle",
      "onSave": {
        "type": "controller",
        "endpoint": "music_service/rtlsdr_radio",
        "method": "saveManualFrequency"
      },
      "saveButton": {
        "label": "Save and Play",
        "data": [
          "manual_fm_frequency"
        ]
      },
      "content": [
        {
          "id": "manual_fm_frequency",
          "element": "input",
          "label": "FM Frequency (MHz)",
          "value": "98.8",
          "doc": "Enter FM frequency (88.0 - 108.0 MHz) and click Save and Play"
        }
      ]
    },
    {
      "id": "scanning",
      "element": "section",
      "label": "Station Scanning",
      "icon": "fa-search",
      "content": [
        {
          "id": "scan_fm",
          "element": "button",
          "label": "Scan FM Stations",
          "onClick": {
            "type": "controller",
            "endpoint": "music_service/rtlsdr_radio",
            "method": "scanFm"
          },
          "doc": "Scan for available FM radio stations"
        },
        {
          "id": "scan_dab",
          "element": "button",
          "label": "Scan DAB Stations",
          "onClick": {
            "type": "controller",
            "endpoint": "music_service/rtlsdr_radio",
            "method": "scanDab"
          },
          "doc": "Scan for available DAB/DAB+ stations (may take 2-3 minutes)"
        }
      ]
    }
  ]
}
